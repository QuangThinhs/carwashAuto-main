# Mat khau MySQL (XAMPP mac dinh de TRONG)
DB_PASSWORD=

# Khoa ky JWT - doi thanh chuoi ngau nhien dai (toi thieu 256 bit / 32 ky tu)
JWT_SECRET=doi-thanh-chuoi-ngau-nhien-dai-toi-thieu-256-bit-xxxxxxxx
